{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "management_address", "share_address"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "management_address": { "type": "string", "minLength": 1 },
    "share_address": { "type": "string", "minLength": 1 },
    "tls_verify": { "type": "boolean" },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "web_ui": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "hostname": { "type": "string", "minLength": 1 },
            "scheme": { "enum": ["http", "https"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "exposure": { "enum": ["trusted_only"] },
            "tls": { "enum": ["letsencrypt_dns", "internal"] },
            "directory_entry": { "$ref": "#/$defs/directory_entry" },
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": { "enum": ["none"] }
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              },
              "then": { "required": ["hostname"] }
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "directory_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "label": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 }
      }
    }
  }
}
