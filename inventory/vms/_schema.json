{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["vmid", "placement", "source", "hardware", "cloud_init"],
  "properties": {
    "vmid": { "type": "integer", "minimum": 100, "maximum": 8999 },
    "description": { "type": "string" },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["ordinary", "operational"] },
        "purpose": { "type": "string", "minLength": 1 },
        "generated": { "type": "boolean" }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": { "host": { "type": "string", "minLength": 1 } }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template"],
      "properties": { "template": { "type": "string", "minLength": 1 } }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cores", "memory"],
      "properties": {
        "cores": { "type": "integer", "minimum": 1 },
        "memory": { "type": "integer", "minimum": 256 },
        "disks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["storage", "size"],
            "properties": {
              "storage": { "type": "string", "minLength": 1 },
              "size": { "type": "string", "minLength": 1 }
            }
          }
        },
        "pci_devices": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host_address", "primary_gpu", "pcie", "rombar"],
            "properties": {
              "host_address": {
                "type": "string",
                "pattern": "^[0-9A-Fa-f]{4}:[0-9A-Fa-f]{2}:[0-9A-Fa-f]{2}\\.[0-7]$"
              },
              "mapping_name": { "type": "string", "minLength": 1 },
              "pci_id": {
                "type": "string",
                "pattern": "^[0-9A-Fa-f]{4}:[0-9A-Fa-f]{4}$"
              },
              "iommu_group": { "type": "integer", "minimum": 0 },
              "subsystem_id": {
                "type": "string",
                "pattern": "^[0-9A-Fa-f]{4}:[0-9A-Fa-f]{4}$"
              },
              "mapping_comment": { "type": "string", "minLength": 1 },
              "mediated_devices": { "type": "boolean" },
              "primary_gpu": { "type": "boolean" },
              "pcie": { "type": "boolean" },
              "rombar": { "type": "boolean" }
            },
            "allOf": [
              {
                "if": { "required": ["mapping_name"] },
                "then": { "required": ["pci_id"] }
              }
            ]
          }
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bridge"],
            "properties": {
              "bridge": { "type": "string", "minLength": 1 },
              "vlan": { "type": "integer", "minimum": 1, "maximum": 4094 },
              "address": { "type": "string", "minLength": 1 },
              "secondary_addresses": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "gateway": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "management_ssh_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["listen_addresses"],
      "properties": {
        "listen_addresses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$"
          },
          "uniqueItems": true
        }
      }
    },
    "cloud_init": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname"],
      "properties": { "hostname": { "type": "string", "minLength": 1 } }
    },
    "instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "dataset", "protocol", "mount_point", "access"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "dataset": { "type": "string", "minLength": 1 },
          "protocol": { "type": "string", "minLength": 1 },
          "mount_point": { "type": "string", "pattern": "^/" },
          "access": { "enum": ["read_only", "read_write"] },
          "options_extra": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "launchable_service_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "launch_order"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "launch_order": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "tailnet_subnet_router": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advertise_routes"],
      "properties": {
        "advertise_routes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "advertise_exit_node": { "type": "boolean" },
        "auth_key_extract": { "type": "string", "minLength": 1 }
      }
    },
    "forgejo_runner_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forgejo_service", "scope", "labels", "concurrency", "cleanup"],
      "properties": {
        "forgejo_service": { "type": "string", "minLength": 1 },
        "scope": { "enum": ["instance"] },
        "labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "concurrency": { "type": "integer", "minimum": 1 },
        "cleanup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workspace", "cache"],
          "properties": {
            "workspace": { "enum": ["after_job"] },
            "cache": { "enum": ["disposable"] }
          }
        },
        "job_containers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "expose_container_runtime_socket": { "type": "boolean" }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "policy": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "ssh_public_key": { "type": "string" }
  }
}
