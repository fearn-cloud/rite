#!/usr/bin/env python3
import argparse
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.backup_configure_apply import backup_configure_plan_from_dict  # noqa: E402
from fortress_inventory.initial_backup_run import (  # noqa: E402
    JsonLogInitialBackupRunClient,
    PveshInitialBackupRunClient,
    trigger_initial_backup_runs,
)


def main():
    args = parse_args(sys.argv[1:])
    with Path(args.plan_json).open() as handle:
        plan = backup_configure_plan_from_dict(json.load(handle))

    client = make_client(plan.host_name)
    result = trigger_initial_backup_runs(plan, client, target_name=args.target or None)
    print(result.render(), end="")
    return 0 if result.success else 1


def parse_args(args):
    parser = argparse.ArgumentParser(prog="scripts/backup-initial-run")
    parser.add_argument("--plan-json", required=True, help="Host-scoped Backup Configure plan JSON")
    parser.add_argument("--target", default="", help="Backup Target to trigger; omit for all pending targets on the Host")
    return parser.parse_args(args)


def make_client(host_name):
    test_log = os.environ.get("FORTRESS_TEST_INITIAL_BACKUP_RUN_LOG")
    if test_log:
        return JsonLogInitialBackupRunClient(host_name, test_log)
    return PveshInitialBackupRunClient(host_name)


if __name__ == "__main__":
    raise SystemExit(main())
