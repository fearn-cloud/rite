#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.model import load_inventory_tree
from fortress_tofu.generate import hcl_identifier


SOPS_EXTRACT = '["pve_tokens"]["tofu"]["value"]'


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        print("usage: scripts/tofu-wrap <tofu-args...>", file=sys.stderr)
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    tofu_root = repo_root / "tofu"
    try:
        token_env = _host_token_env(repo_root)
        subprocess.run([str(_script_root() / "tofu-generate"), str(repo_root)], check=True)
        env = os.environ.copy()
        env.update(token_env)
        return subprocess.run(["tofu", *argv], cwd=tofu_root, env=env).returncode
    except WrapperError as error:
        print(error, file=sys.stderr)
        return 1
    except subprocess.CalledProcessError as error:
        return error.returncode or 1


class WrapperError(Exception):
    pass


def _host_token_env(repo_root):
    model = load_inventory_tree(repo_root)
    env = {}
    for host in sorted(model.hosts):
        host_sops = repo_root / "inventory" / "hosts" / f"{host}.sops.yaml"
        if not host_sops.is_file():
            raise WrapperError(f"missing Host Sibling SOPS File for Host {host}: {host_sops}")
        token = _decrypt_tofu_token(host, host_sops)
        if not token:
            raise WrapperError(f"missing pve_tokens.tofu.value in Host Sibling SOPS File for Host {host}: {host_sops}")
        env[f"TF_VAR_pve_token_{hcl_identifier(host)}"] = token
    return env


def _script_root():
    return Path(__file__).resolve().parent


def _decrypt_tofu_token(host, host_sops):
    try:
        return subprocess.run(
            ["sops", "--decrypt", "--extract", SOPS_EXTRACT, str(host_sops)],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        ).stdout.strip()
    except subprocess.CalledProcessError as error:
        raise WrapperError(
            f"failed to decrypt pve_tokens.tofu.value for Host {host} from {host_sops}"
        ) from error


if __name__ == "__main__":
    raise SystemExit(main())
