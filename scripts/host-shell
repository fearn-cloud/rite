#!/usr/bin/env python3
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


def main():
    parsed = parse_args(sys.argv[1:])
    if parsed is None:
        print("usage: scripts/host-shell <host> [-- <command>...]", file=sys.stderr)
        return 2
    host, remote_command = parsed

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    host_yaml = repo_root / "inventory" / "hosts" / f"{host}.yaml"
    host_sops = repo_root / "inventory" / "hosts" / f"{host}.sops.yaml"
    if not host_yaml.is_file():
        print(f"Host {host!r} is not declared at {host_yaml}", file=sys.stderr)
        return 1
    if not host_sops.is_file():
        print(
            f"Host Sibling SOPS File is required at {host_sops}. Run Host Bootstrap first.",
            file=sys.stderr,
        )
        return 1

    hostvars = _load_hostvars(repo_root)
    host_vars = _ansible_value(hostvars.get(host, {}))

    ansible_host = host_vars.get("ansible_host")
    if not ansible_host:
        print(f"Host {host!r} has no ansible_host in Ansible Inventory", file=sys.stderr)
        return 1

    ansible_user = host_vars.get("ansible_user")
    if not ansible_user:
        print(f"Host {host!r} has no ansible_user in Ansible Inventory", file=sys.stderr)
        return 1

    key_file = host_vars.get("ansible_ssh_private_key_file")
    if not key_file:
        print(f"Host {host!r} has no ansible_ssh_private_key_file in Ansible Inventory", file=sys.stderr)
        return 1

    ssh_args = ["ssh"]
    if not remote_command:
        ssh_args.append("-t")
    common_args = host_vars.get("ansible_ssh_common_args")
    if common_args:
        ssh_args.extend(shlex.split(common_args))
    ssh_args.extend(["-i", key_file, f"{ansible_user}@{ansible_host}"])
    ssh_args.extend(shlex.quote(arg) for arg in remote_command)
    return subprocess.run(
        [
            str(repo_root / "scripts" / "decrypt-keys"),
            str(host_sops),
            "--",
            *ssh_args,
        ]
    ).returncode


def parse_args(argv):
    if len(argv) == 1:
        return argv[0].removeprefix("host="), []
    if len(argv) >= 3 and argv[1] == "--":
        return argv[0].removeprefix("host="), argv[2:]
    return None


def _load_hostvars(repo_root):
    result = subprocess.run(
        [
            "ansible-inventory",
            "-i",
            str(repo_root / "inventory" / "fortress.yaml"),
            "--list",
        ],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
    )
    inventory = json.loads(result.stdout)
    return inventory.get("_meta", {}).get("hostvars", {})


def _ansible_value(value):
    if isinstance(value, dict) and set(value) == {"__ansible_unsafe"}:
        return value["__ansible_unsafe"]
    if isinstance(value, dict):
        return {key: _ansible_value(child) for key, child in value.items()}
    if isinstance(value, list):
        return [_ansible_value(child) for child in value]
    return value


if __name__ == "__main__":
    raise SystemExit(main())
