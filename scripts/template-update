#!/usr/bin/env python3
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_workflows.runner import CommandPhase, OperatorWorkflowRunner  # noqa: E402
from fortress_workflows.template_update import (  # noqa: E402
    TemplateUpdatePlanError,
    build_template_update_plan,
    template_update_lineage_report,
)


def main():
    parsed = parse_args(sys.argv[1:])
    if parsed is None:
        print(
            "usage: scripts/template-update host=<host|all> template=<template> [keep_on_fail=<true|false>]",
            file=sys.stderr,
        )
        return 2

    host_name, template_name, keep_on_fail = parsed
    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    try:
        plan = build_template_update_plan(repo_root, host_name, template_name, keep_on_fail)
    except TemplateUpdatePlanError as error:
        print(str(error), file=sys.stderr)
        return 1

    for line in template_update_lineage_report(repo_root, template_name):
        print(line)

    result = OperatorWorkflowRunner(cwd=repo_root).run(plan)
    if not result.success:
        render_failure(plan, result, keep_on_fail)
    return result.return_code


def parse_args(argv):
    if len(argv) not in (2, 3):
        return None

    values = {}
    for arg in argv:
        if "=" not in arg:
            return None
        key, value = arg.split("=", 1)
        if key not in ("host", "template", "keep_on_fail"):
            return None
        values[key] = value.strip('"')
    if "host" not in values or "template" not in values:
        return None
    keep_on_fail = values.get("keep_on_fail", "false").lower()
    if keep_on_fail not in ("true", "false"):
        return None
    return values["host"], values["template"], keep_on_fail == "true"


def render_failure(plan, result, keep_on_fail):
    failed_phases = {phase.step_id: phase for phase in result.phase_results if phase.status == "failed"}
    for step in plan.steps:
        if not isinstance(step, CommandPhase) or step.id not in failed_phases:
            continue
        failed = failed_phases[step.id]
        suffix = f": {failed.failure_detail}" if failed.failure_detail else ""
        print(f"{step.diagnostic_label}{suffix}", file=sys.stderr)
        if step.id.startswith("template-verify"):
            preservation = "preserved" if keep_on_fail else "not preserved"
            print(
                f"Template Verification artifacts {preservation} according to keep_on_fail={bool_arg(keep_on_fail)}",
                file=sys.stderr,
            )
        return


def bool_arg(value):
    return "true" if value else "false"


if __name__ == "__main__":
    raise SystemExit(main())
