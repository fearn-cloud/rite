#!/usr/bin/env python3
import os
import json
import subprocess
import sys
from pathlib import Path


def main():
    if len(sys.argv) != 2:
        print("usage: scripts/vm-configure <vm>", file=sys.stderr)
        return 2

    vm = sys.argv[1].removeprefix("vm=")
    script_root = Path(__file__).resolve().parents[1]
    repo_root = Path(os.environ.get("FORTRESS_ROOT", script_root))
    if str(script_root) not in sys.path:
        sys.path.insert(0, str(script_root))
    from fortress_inventory.model import load_inventory_tree

    vm_yaml = repo_root / "inventory" / "vms" / f"{vm}.yaml"
    vm_sops = repo_root / "inventory" / "vms" / f"{vm}.sops.yaml"
    if not vm_yaml.is_file():
        print(f"VM {vm!r} is not declared at {vm_yaml}", file=sys.stderr)
        return 1
    if not vm_sops.is_file():
        print(f"VM Sibling SOPS File is required at {vm_sops}. Run VM Prepare first.", file=sys.stderr)
        return 1

    sops_files = [str(vm_sops)]
    model = load_inventory_tree(repo_root)
    runner_runtime = model.vms.get(vm, {}).get("forgejo_runner_runtime")
    if isinstance(runner_runtime, dict):
        forgejo_service = model.services.get(runner_runtime.get("forgejo_service"), {})
        forgejo_backend_vm = forgejo_service.get("backend", {}).get("vm")
        forgejo_backend_sops = repo_root / "inventory" / "vms" / f"{forgejo_backend_vm}.sops.yaml"
        if forgejo_backend_vm and forgejo_backend_sops.is_file():
            sops_files.append(str(forgejo_backend_sops))

    result = subprocess.run(
        [
            str(repo_root / "scripts" / "decrypt-keys"),
            *sops_files,
            "--",
            "ansible-playbook",
            str(repo_root / "ansible" / "playbooks" / "vm-configure.yml"),
            "-i",
            str(repo_root / "inventory" / "fortress.yaml"),
            "--limit",
            vm,
            "--extra-vars",
            json.dumps({"configure_vm": vm, "fortress_vm_sops_file": str(vm_sops)}),
        ],
    )
    if result.returncode != 0:
        return result.returncode or 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
