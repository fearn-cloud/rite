#!/usr/bin/env python3
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_workflows.host_readiness import (  # noqa: E402
    HostReadinessPlanError,
    build_host_readiness_plan,
    render_host_readiness_summary,
)
from fortress_workflows.runner import OperatorWorkflowRunner  # noqa: E402


def main():
    parsed = parse_args(sys.argv[1:])
    if parsed is None:
        print(
            "usage: scripts/host-up <host> [endpoint=<nas-endpoint|all>] "
            "[auto_confirm=<true|false>] [keep_on_fail=<true|false>]",
            file=sys.stderr,
        )
        return 2
    host_name, endpoint_arg, auto_confirm, keep_on_fail = parsed
    if host_name.startswith("host="):
        host = host_name.removeprefix("host=")
        print(
            f"host-up takes the host name as a positional argument; run `just host-up {host}`.",
            file=sys.stderr,
        )
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    try:
        resolved = build_host_readiness_plan(repo_root, host_name, endpoint_arg, auto_confirm, keep_on_fail)
    except HostReadinessPlanError as error:
        print(str(error), file=sys.stderr)
        print("host-readiness: failed")
        return 1

    result = OperatorWorkflowRunner(cwd=repo_root, auto_confirm=auto_confirm).run(resolved.plan)
    for phase in result.phase_results:
        if phase.status != "failed":
            continue
        print(f"{phase.step_id} failed: {phase.failure_detail}", file=sys.stderr)
        if keep_on_fail and phase.step_id.startswith("acceptance "):
            print(
                "keep_on_fail=true preserved artifacts may collide with later acceptance cells; stopping.",
                file=sys.stderr,
            )
    for line in render_host_readiness_summary(resolved, result):
        print(line)
    return result.return_code


def parse_args(argv):
    if not argv:
        return None
    host_name = argv[0]
    values = {
        "endpoint": "all",
        "auto_confirm": "false",
        "keep_on_fail": "false",
    }
    for arg in argv[1:]:
        if "=" not in arg:
            return None
        key, value = arg.split("=", 1)
        if key not in values:
            return None
        values[key] = value.strip('"')
    for key in ("auto_confirm", "keep_on_fail"):
        if values[key].lower() not in ("true", "false"):
            return None
        values[key] = values[key].lower() == "true"
    return host_name, values["endpoint"], values["auto_confirm"], values["keep_on_fail"]


if __name__ == "__main__":
    raise SystemExit(main())
