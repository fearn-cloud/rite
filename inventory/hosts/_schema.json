{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    { "$ref": "#/$defs/host" },
    { "$ref": "#/$defs/sibling_sops" }
  ],
  "$defs": {
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proxmox"],
      "properties": {
        "proxmox": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pve_node_name"],
          "properties": {
            "pve_node_name": { "type": "string", "minLength": 1 },
            "endpoint": { "type": "string", "minLength": 1 },
            "templates": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          }
        },
        "hardware": { "type": "object" },
        "network": { "type": "object" },
        "gpu_passthrough": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "vendor": { "enum": ["intel", "amd", "none"] },
            "mode": { "enum": ["sriov", "full", "none"] },
            "iommu": { "enum": ["intel", "amd", "none"] },
            "sriov_vfs": { "type": "integer", "minimum": 0 },
            "blacklist_host_driver": { "type": "boolean" }
          }
        }
      }
    },
    "sibling_sops": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ssh_keys", "sops"],
      "properties": {
        "ssh_keys": { "type": "object", "minProperties": 1 },
        "sops": { "$ref": "#/$defs/sops_metadata" }
      }
    },
    "sops_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "age": { "type": "array" },
        "lastmodified": { "type": "string" },
        "mac": { "type": "string" },
        "unencrypted_suffix": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
