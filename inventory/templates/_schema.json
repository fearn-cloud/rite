{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "vmid", "source", "hardware"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "vmid": { "type": "integer", "minimum": 9000, "maximum": 9999 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "checksum"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "checksum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "enum": ["sha512"] },
            "value": { "type": "string", "pattern": "^[A-Fa-f0-9]{128}$" }
          }
        }
      }
    },
    "customize": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "run_commands": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "hardware": {
      "type": "object",
      "required": ["cores", "memory"],
      "additionalProperties": true,
      "properties": {
        "cores": { "type": "integer", "minimum": 1 },
        "memory": { "type": "integer", "minimum": 256 },
        "disk_storage": { "type": "string", "minLength": 1, "default": "fast" },
        "cloud_init_storage": { "type": "string", "minLength": 1, "default": "local-lvm" },
        "bridge": { "type": "string", "minLength": 1, "default": "vmbr0" },
        "network_model": { "type": "string", "minLength": 1, "default": "virtio" },
        "scsi_controller": { "type": "string", "minLength": 1, "default": "virtio-scsi-pci" },
        "bios": { "type": "string", "minLength": 1 },
        "machine": { "type": "string", "minLength": 1 },
        "agent_enabled": { "type": "boolean" },
        "serial_console": { "type": "boolean" }
      }
    }
  }
}
