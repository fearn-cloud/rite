#!/usr/bin/env python3
import argparse
import concurrent.futures
import os
import subprocess
import sys
import time
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
SERIAL_MODULES = {
    # This role shells out to ansible-playbook and has shown intermittent
    # side effects when run beside other Ansible-heavy module tests.
    "tests.test_vm_nfs_mounts_role",
}


def test_modules(test_dir):
    return [
        f"{test_dir.name}.{path.stem}"
        for path in sorted(test_dir.glob("test_*.py"))
    ]


def run_module(module):
    started = time.monotonic()
    result = subprocess.run(
        [sys.executable, "-m", "unittest", module],
        cwd=REPO_ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return {
        "module": module,
        "returncode": result.returncode,
        "stdout": result.stdout,
        "stderr": result.stderr,
        "seconds": time.monotonic() - started,
    }


def default_jobs(module_count):
    env_jobs = os.environ.get("FORTRESS_TEST_JOBS")
    if env_jobs:
        return max(1, int(env_jobs))
    return max(1, min(module_count, os.cpu_count() or 2, 8))


def main(argv=None):
    parser = argparse.ArgumentParser(description="Run unittest modules in parallel.")
    parser.add_argument("-j", "--jobs", type=int, help="number of test modules to run at once")
    parser.add_argument("modules", nargs="*", help="optional unittest module names")
    args = parser.parse_args(argv)

    test_dir = REPO_ROOT / "tests"
    modules = args.modules or test_modules(test_dir)
    if not modules:
        print("No test modules found.", file=sys.stderr)
        return 1

    serial_modules = [module for module in modules if module in SERIAL_MODULES]
    parallel_modules = [module for module in modules if module not in SERIAL_MODULES]
    jobs = args.jobs or default_jobs(len(parallel_modules))
    print(f"Running {len(parallel_modules)} test modules with {jobs} jobs", flush=True)
    if serial_modules:
        print(f"Running {len(serial_modules)} test modules serially", flush=True)

    failures = []
    started = time.monotonic()
    with concurrent.futures.ThreadPoolExecutor(max_workers=jobs) as executor:
        futures = {executor.submit(run_module, module): module for module in parallel_modules}
        for future in concurrent.futures.as_completed(futures):
            result = future.result()
            status = "ok" if result["returncode"] == 0 else "FAIL"
            print(f"{status:4} {result['seconds']:6.2f}s {result['module']}", flush=True)
            if result["returncode"] != 0:
                failures.append(result)

    for module in serial_modules:
        result = run_module(module)
        status = "ok" if result["returncode"] == 0 else "FAIL"
        print(f"{status:4} {result['seconds']:6.2f}s {result['module']}", flush=True)
        if result["returncode"] != 0:
            failures.append(result)

    if failures:
        print(flush=True)
        for failure in failures:
            print(f"===== {failure['module']} failed =====", flush=True)
            if failure["stdout"]:
                print(failure["stdout"], end="")
            if failure["stderr"]:
                print(failure["stderr"], end="", file=sys.stderr)

    elapsed = time.monotonic() - started
    print(f"Finished in {elapsed:.2f}s", flush=True)
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
