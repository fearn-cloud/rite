#!/usr/bin/env python3
import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.backup_configure_apply import (  # noqa: E402
    PveshBackupJobClient,
    apply_backup_configure_plan,
    backup_configure_plans_from_dict,
)


def main():
    args = parse_args(sys.argv[1:])
    with Path(args.plan_json).open() as handle:
        plans = backup_configure_plans_from_dict(json.load(handle))

    for plan in plans:
        result = apply_backup_configure_plan(
            plan,
            PveshBackupJobClient(plan.host_name),
            confirm_prune=confirm_prune,
            auto_confirm_prune=args.auto_confirm_prune,
            reporter=report,
        )
        if result.message:
            print(result.message, file=sys.stderr)
        if not result.success:
            return 1
    return 0


def parse_args(args):
    parser = argparse.ArgumentParser(prog="scripts/backup-configure-apply")
    parser.add_argument("--plan-json", required=True, help="Host-scoped or fleet Backup Configure plan JSON")
    parser.add_argument(
        "--auto-confirm-prune",
        action="store_true",
        help="Allow pruning obsolete fortress-owned Backup Jobs without prompting",
    )
    return parser.parse_args(args)


def confirm_prune(plan, actions):
    print(f"Prune {len(actions)} obsolete fortress-owned Backup Job(s) on Host {plan.host_name}? Type prune: ", end="", flush=True)
    return sys.stdin.readline().strip() == "prune"


def report(message):
    print(message, flush=True)


if __name__ == "__main__":
    raise SystemExit(main())
