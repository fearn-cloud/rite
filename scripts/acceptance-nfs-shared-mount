#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(REPO_ROOT))

from fortress_acceptance.lifecycle import AcceptanceTestLifecycle, phase_detail, run, ssh_check  # noqa: E402
from fortress_inventory.model import load_inventory_tree  # noqa: E402


LIFECYCLE = AcceptanceTestLifecycle(
    policy_name="nfs-shared-mount",
    artifact_label="NFS shared-mount Acceptance",
    purpose="nfs-shared-mount-acceptance",
    bridge_error_label="NFS Acceptance",
)


def main():
    args = parse_args(sys.argv[1:])
    if args is None:
        print(
            "usage: scripts/acceptance-nfs-shared-mount "
            "host=<host> template=<template> endpoint=<nas-endpoint> "
            "[auto_confirm=<true|false>] [keep_on_fail=<true|false>]",
            file=sys.stderr,
        )
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", REPO_ROOT))
    early_overwrite_check = LIFECYCLE.refuse_existing_policy_artifacts(repo_root)
    if early_overwrite_check != 0:
        return early_overwrite_check

    inventory = load_inventory_tree(repo_root)
    resolved = LIFECYCLE.resolve_intent(repo_root, inventory, args)
    if isinstance(resolved, int):
        return resolved
    intent = resolved

    overwrite_check = LIFECYCLE.refuse_existing_artifacts(repo_root, intent["vms"])
    if overwrite_check != 0:
        return overwrite_check
    dataset_overwrite_check = LIFECYCLE.refuse_existing_dataset_artifact(repo_root, intent)
    if dataset_overwrite_check != 0:
        return dataset_overwrite_check

    print_intent(intent)
    if not args["auto_confirm"] and not confirm():
        print("nfs shared-mount acceptance: cancelled")
        return 1

    generated = False
    provisioned = []
    try:
        progress("generating temporary Inventory artifacts")
        LIFECYCLE.write_generated_dataset(repo_root, intent)
        LIFECYCLE.write_generated_vms(repo_root, intent)
        generated = True
        progress(f"reconciling Ephemeral Dataset and Derived NFS Share on NAS Endpoint {intent['endpoint']}")
        reconcile = LIFECYCLE.run_reconcile(repo_root, intent, destroy=False)
        if reconcile.returncode != 0:
            return LIFECYCLE.failed_after_generation(
                repo_root,
                intent,
                "NAS Reconcile",
                reconcile,
                args["keep_on_fail"],
                generated,
                provisioned,
                require_nas_cleanup=False,
            )
        assertion = LIFECYCLE.assert_reconcile_share(reconcile.stdout, intent)
        if assertion:
            return LIFECYCLE.failed_after_generation(
                repo_root,
                intent,
                "NAS Reconcile assertion",
                assertion,
                args["keep_on_fail"],
                generated,
                provisioned,
            )

        for vm in intent["vms"]:
            progress(f"provisioning {vm['role']} Acceptance VM {vm['name']}")
            command = [str(repo_root / "scripts" / "vm-up"), vm["name"]]
            provisioned.append(vm["name"])
            if args["auto_confirm"]:
                command.append("--auto-confirm")
                up = run(command)
            else:
                up = run(command, input_text=f"apply {vm['name']}\n")
            if up.returncode != 0:
                return LIFECYCLE.failed_after_generation(
                    repo_root,
                    intent,
                    f"vm-up {vm['name']}",
                    up,
                    args["keep_on_fail"],
                    generated,
                    provisioned,
                )

        progress("verifying shared Mount read/write/delete contract")
        verification = verify_shared_mount(repo_root, intent)
        if verification.returncode != 0:
            return LIFECYCLE.failed_after_generation(repo_root, intent, "verification", verification, args["keep_on_fail"], generated, provisioned)

        progress("cleaning up generated Acceptance resources")
        cleanup = LIFECYCLE.cleanup_resources(repo_root, intent, provisioned)
        if cleanup.returncode != 0:
            print(f"cleanup failed: {phase_detail(cleanup)}", file=sys.stderr)
            return 1
        print("nfs shared-mount acceptance: passed")
        return 0
    except OSError as error:
        result = subprocess.CompletedProcess([], 1, "", str(error))
        return LIFECYCLE.failed_after_generation(repo_root, intent, "workflow", result, args["keep_on_fail"], generated, provisioned)


def parse_args(argv):
    values = {}
    for arg in argv:
        if "=" not in arg:
            return None
        key, value = arg.split("=", 1)
        values[key] = value.strip('"')
    if set(values) - {"host", "template", "endpoint", "auto_confirm", "keep_on_fail"}:
        return None
    if not {"host", "template", "endpoint"} <= set(values):
        return None
    for key in ("auto_confirm", "keep_on_fail"):
        values[key] = values.get(key, "false").lower()
        if values[key] not in ("true", "false"):
            return None
        values[key] = values[key] == "true"
    return values


def print_intent(intent):
    print("NFS shared-mount Acceptance Test intent")
    print(f"Host: {intent['host']}")
    print(f"Template: {intent['template']}")
    print(f"NAS Endpoint: {intent['endpoint']}")
    print(f"Dataset: {intent['dataset']['name']}")
    for vm in intent["vms"]:
        print(f"{vm['role']}: {vm['name']} VMID {vm['vmid']} {vm['address']}")


def confirm():
    response = input("Type 'acceptance nfs shared mount' to continue: ")
    return response == "acceptance nfs shared mount"


def progress(message):
    print(f"nfs shared-mount acceptance: {message}", flush=True)


def verify_shared_mount(repo_root, intent):
    mount_point = intent["policy"]["mount"]["mount_point"]
    primary, peer = intent["vms"]
    primary_file = f"{mount_point}/fortress-primary.txt"
    peer_file = f"{mount_point}/fortress-peer.txt"
    checks = [
        *LIFECYCLE.mount_health_checks(intent),
        ssh_check(primary, ["sh", "-lc", f"printf primary > {primary_file}"]),
        ssh_check(peer, ["cat", primary_file], "primary"),
        ssh_check(peer, ["sh", "-lc", f"printf peer > {peer_file}"]),
        ssh_check(primary, ["cat", peer_file], "peer"),
        ssh_check(peer, ["rm", primary_file]),
        ssh_check(primary, ["test", "!", "-e", primary_file]),
        ssh_check(primary, ["rm", peer_file]),
        ssh_check(peer, ["test", "!", "-e", peer_file]),
    ]
    return LIFECYCLE.verify_checks(repo_root, checks)


if __name__ == "__main__":
    raise SystemExit(main())
